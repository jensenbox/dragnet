# Copy to .env next to docker-compose.yml and fill in real values.
# Never commit the real .env.

# Django — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DEBUG=false
ALLOWED_HOSTS=192.168.16.10,localhost
TIME_ZONE=America/Vancouver

# put.io OAuth token — create an app at https://app.put.io/oauth and use its OAuth token
PUTIO_OAUTH_TOKEN=

# Password for bitmagnet's Postgres (internal to the compose network)
POSTGRES_PASSWORD=

# TMDB v3 API key (themoviedb.org → Settings → API) for bitmagnet's classifier
TMDB_API_KEY=

# Bearer token for POST /api/download/ (programmatic sends, e.g. Claude Code).
# Leave empty to disable the API. Generate like SECRET_KEY.
DRAGNET_API_TOKEN=

# Optional: first deploy bootstraps this Django admin account
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=
